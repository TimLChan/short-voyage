voyager:
    api:
        base_url: "https://cloudserver.nz:443/api/v1"
        token: "" # get this from https://cloudserver.nz/account#api-tokens
    project:
        name: "main"
        description: "Test project for short-voyage"
    server:
        location: 1 # auckland
        plan: 29 # xxs
        operatingsystem: 34 # debian 12
        ssh_keys: [] # optional: preferred SSH key ID(s). If empty or not found, uses first key from account
        fail2ban: true
        runcmd: |
            echo 'net.ipv4.ip_forward = 1' | sudo tee -a /etc/sysctl.d/99-tailscale.conf
            echo 'net.ipv6.conf.all.forwarding = 1' | sudo tee -a /etc/sysctl.d/99-tailscale.conf
            sudo sysctl -p /etc/sysctl.d/99-tailscale.conf

tailscale:
    enabled: true # set false to skip tailscale auth/key generation
    exit_node: true
    api:
        base_url: "https://api.tailscale.com/api/v2" # required when enabled=true
        clientid: "" # required when enabled=true
        clientsecret: "" # required when enabled=true
        tailnet: "" # required when enabled=true
        scopes:
            - "auth_keys"
    tags:
        - "voyager"
